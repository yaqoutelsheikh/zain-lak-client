{
    "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false
    },
    "formatter": {
        "enabled": false
    },
    "linter": {
        "enabled": true,
        "domains": {
            "react": "recommended",
            "next": "recommended",
            "test": "recommended",
            "project": "recommended"
        },
        "rules": {
            "recommended": true,
            "suspicious": {
                "noConsole": "error",
                "noImportCycles": "error"
            },
            "style": {
                "useFilenamingConvention": {
                    "level": "error",
                    "options": {
                        "filenameCases": ["kebab-case"],
                        "requireAscii": true
                    }
                }
            }
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "overrides": [
        {
            "includes": ["src/lib/log/**", "src/app/*.tsx", "src/stores/*.ts"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off",
                        "noDocumentCookie": "off"
                    }
                }
            }
        }
    ]
}
